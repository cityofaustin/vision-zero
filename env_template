# copy this file to .env and fill in the values

# credentials specific to local database
POSTGRES_PASSWORD="visionzero"
POSTGRES_USER="visionzero"
POSTGRES_DB="vision_zero"
POSTGRES_HOST_AUTH_METHOD="trust"
PGDATA="/var/lib/postgresql/data/pgdata"

# postgres tuning for local docker stack (docker-compose.yml)
PG_MAINTENANCE_WORK_MEM="1GB"
PG_MAX_WAL_SIZE="5GB"
PG_SHARED_BUFFERS="2GB"
PG_WORK_MEM="64MB"
PG_EFFECTIVE_CACHE_SIZE="6GB"
PG_CHECKPOINT_COMPLETION_TARGET="0.9"

# developer's personal credentials to VZ read reaplica
RR_USERNAME=""
RR_PASSWORD=""
RR_HOSTNAME=""
RR_DATABASE="vision_zero"
